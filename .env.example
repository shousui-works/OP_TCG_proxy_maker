# Backend - GCS設定（本番用、ローカル開発時は不要）
# CARD_IMAGES_BUCKET=your-project-card-images
# DATA_FILES_BUCKET=your-project-data-files
# GCS_PUBLIC_URL=https://storage.googleapis.com/your-project-card-images

# Frontend - API Base URL
VITE_API_BASE=http://localhost:8000

# Frontend - Firebase Configuration
VITE_FIREBASE_API_KEY=your-firebase-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Frontend - Admin email（カンマ区切りで複数指定可）
VITE_ADMIN_EMAIL=admin@example.com
